{
  "lexicon": 1,
  "id": "eu.atchef.recipe",
  "defs": {
    "main": {
      "type": "record",
      "description": "A cooking recipe with ingredients, instructions, and metadata",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "content", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 640,
            "maxGraphemes": 64,
            "description": "Recipe title"
          },
          "portions": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of servings"
          },
          "time": {
            "type": "integer",
            "minimum": 1,
            "description": "Total time in minutes"
          },
          "content": {
            "type": "string",
            "maxLength": 15000,
            "maxGraphemes": 3000,
            "description": "Recipe content in Cooklang format"
          },
          "image": {
            "type": "blob",
            "accept": ["image/png", "image/jpeg", "image/webp"],
            "maxSize": 1000000,
            "description": "Cover image"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "maxGraphemes": 200,
            "description": "Brief recipe description or summary"
          },
          "prepTime": {
            "type": "integer",
            "minimum": 0,
            "description": "Preparation time in minutes"
          },
          "cookTime": {
            "type": "integer",
            "minimum": 0,
            "description": "Cooking time in minutes"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the recipe was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the recipe was last updated"
          }
        }
      }
    }
  }
}
